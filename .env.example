# 공공데이터포털에서 발급받은 ServiceKey (Decoding 값)
# https://www.data.go.kr 에서 "나라장터 입찰공고정보서비스" 등 활용신청 후 마이페이지 > 개발계정에서 확인
NARA_API_KEY=your_decoded_service_key_here

# 트랜스포트 모드: stdio (로컬) | http (원격)
TRANSPORT=stdio

# HTTP 모드용 (원격 배포 시)
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# SQLite 상태 DB 경로 (기본: ~/.narajangteo-pro/state.db)
STATE_DB_PATH=

# 캐시 TTL (초). 동일 API 호출 결과를 메모리 캐시. 기본 300
CACHE_TTL=300

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
